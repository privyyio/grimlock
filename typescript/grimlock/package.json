{
  "name": "@privyy-io/grimlock",
  "version": "1.0.0",
  "description": "Versioned cryptographic operations module for privyy.io.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "tsx test.ts",
    "test:node": "node --loader ts-node/esm test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cryptography",
