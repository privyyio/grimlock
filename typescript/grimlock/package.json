    "@vitest/browser": "^4.0.16",
    "@vitest/browser-playwright": "^4.0.16",
    "playwright": "^1.57.0",
    "ts-node": "^10.9.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.16"
